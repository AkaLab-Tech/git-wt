#!/usr/bin/env bash
# git-wt — streamlined git worktree workflow
# https://github.com/AkaLab-Tech/git-wt
set -euo pipefail

VERSION="0.3.0"

# --- colors -----------------------------------------------------------------
if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then
  C_RESET=$'\033[0m'
  C_DIM=$'\033[2m'
  C_BOLD=$'\033[1m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_MAGENTA=$'\033[35m'
  C_CYAN=$'\033[36m'
else
  C_RESET= C_DIM= C_BOLD= C_RED= C_GREEN= C_YELLOW= C_BLUE= C_MAGENTA= C_CYAN=
fi

msg()  { printf '%s\n' "$*" >&2; }
info() { printf '%b\n' "${C_BLUE}==>${C_RESET} $*" >&2; }
warn() { printf '%b\n' "${C_YELLOW}warning:${C_RESET} $*" >&2; }
err()  { printf '%b\n' "${C_RED}error:${C_RESET} $*" >&2; }
die()  { err "$*"; exit 1; }

# Pretty report emitted after a switch/create/remove.
# $1=action (e.g. "switched", "created"), $2=branch, $3=path, $4+=extra hints lines
report() {
  local action="$1" branch="$2" path="$3"; shift 3
  printf '\n' >&2
  printf '%b\n' "${C_GREEN}${C_BOLD}✓${C_RESET} ${C_BOLD}${action}${C_RESET} worktree" >&2
  printf '%b\n' "  ${C_DIM}branch${C_RESET}  ${C_CYAN}${branch}${C_RESET}" >&2
  printf '%b\n' "  ${C_DIM}path${C_RESET}    ${C_MAGENTA}${path}${C_RESET}" >&2
  if [ "$#" -gt 0 ]; then
    printf '\n%b\n' "  ${C_DIM}next:${C_RESET}" >&2
    local line
    for line in "$@"; do
      printf '%b\n' "    ${C_DIM}\$${C_RESET} ${line}" >&2
    done
  fi
  printf '\n' >&2
}

usage() {
  cat >&2 <<'EOF'
git-wt — streamlined git worktree workflow

Usage:
  git wt switch [<branch>] [--from <base>] [--no-env] [--no-deps] [--yes|-y]
                             Switch to worktree for <branch> (creates if missing).
                             No arg opens an fzf picker over existing worktrees.
                             --from cuts a NEW branch from <base> (any commit-ish:
                             local ref, origin/<name>, SHA). Errors if <branch>
                             already exists in a worktree, locally, or on origin.
                             Does not set upstream tracking; no auto-fetch.

                             On create, .env / .env.* files are copied from the
                             main worktree (never overwriting), then a per-
                             toolchain install prompt is shown for detected
                             package managers (npm/pnpm/yarn/bun, poetry/pipenv/
                             pip, cargo, go, bundler, composer).
                               --no-env       skip env-file copy
                               --no-deps      skip install prompt entirely
                               --yes / -y     auto-accept every install prompt
                             Env-var equivalents (set to "1"):
                               GWT_NO_ENV, GWT_NO_DEPS, GWT_ASSUME_YES
                             Non-tty stdin behaves as --no-deps (env copy still
                             runs); use --yes to force an install in CI.

  git wt list                List worktrees (marks the current one).
  git wt rm <branch>         Remove the worktree for <branch>.
  git wt help                Show this help.
  git wt version             Show version.

Note: `switch` needs a shell wrapper to `cd` into the target worktree. It is
installed into your shell rc by install.sh.
EOF
}

require_git_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || die "not inside a git repository"
}

main_worktree_path() {
  git worktree list --porcelain | awk '/^worktree /{print $2; exit}'
}

worktrees_root() {
  local main parent
  main=$(main_worktree_path)
  parent=$(dirname "$main")
  printf '%s/%s-worktrees\n' "$parent" "$(basename "$main")"
}

sanitize_branch() {
  printf '%s\n' "$1" | tr '/' '-'
}

worktree_path_for_branch() {
  local branch="$1"
  git worktree list --porcelain | awk -v b="refs/heads/$branch" '
    /^worktree /{p=$2}
    /^branch /{ if ($2==b) { print p; exit } }
  '
}

local_branch_exists()  { git show-ref --verify --quiet "refs/heads/$1"; }
remote_branch_exists() { git show-ref --verify --quiet "refs/remotes/origin/$1"; }

# bootstrap_env_files <source-dir> <dest-dir>
# Copies .env and .env.* files from source to dest. Never overwrites — warns on collision.
# Silently does nothing if source has no matching files.
bootstrap_env_files() {
  local src="$1" dst="$2"
  [ -d "$src" ] || return 0
  local f base
  for f in "$src"/.env "$src"/.env.*; do
    [ -f "$f" ] || continue
    base=$(basename "$f")
    if [ -e "$dst/$base" ]; then
      warn "env-copy: ${C_CYAN}${base}${C_RESET} already exists in destination, skipping"
      continue
    fi
    if cp "$f" "$dst/$base" 2>/dev/null; then
      info "copied env file ${C_CYAN}${base}${C_RESET}"
    else
      warn "failed to copy ${C_CYAN}${base}${C_RESET} to ${C_MAGENTA}${dst}${C_RESET}"
    fi
  done
}

# detect_toolchains <dir>
# Emits "<toolchain>|<install command>" lines on stdout for each detected marker file.
# Multiple toolchains (polyglot repos) are supported by emitting one line each.
detect_toolchains() {
  local d="$1"
  if [ -f "$d/pnpm-lock.yaml" ]; then
    printf '%s\n' "pnpm|pnpm install"
  elif [ -f "$d/yarn.lock" ]; then
    printf '%s\n' "yarn|yarn install"
  elif [ -f "$d/bun.lockb" ] || [ -f "$d/bun.lock" ]; then
    printf '%s\n' "bun|bun install"
  elif [ -f "$d/package-lock.json" ] || [ -f "$d/package.json" ]; then
    printf '%s\n' "npm|npm install"
  fi
  if [ -f "$d/poetry.lock" ]; then
    printf '%s\n' "poetry|poetry install"
  elif [ -f "$d/Pipfile" ]; then
    printf '%s\n' "pipenv|pipenv install"
  elif [ -f "$d/requirements.txt" ]; then
    printf '%s\n' "pip|pip install -r requirements.txt"
  elif [ -f "$d/pyproject.toml" ]; then
    warn "detected pyproject.toml without poetry.lock or requirements.txt; install command is ambiguous, skipping"
  fi
  [ -f "$d/Cargo.toml" ]     && printf '%s\n' "cargo|cargo fetch"
  [ -f "$d/go.mod" ]         && printf '%s\n' "go|go mod download"
  [ -f "$d/Gemfile" ]        && printf '%s\n' "bundler|bundle install"
  [ -f "$d/composer.json" ]  && printf '%s\n' "composer|composer install"
  return 0
}

# prompt_install <dest> <assume_yes>
# For each detected toolchain: shows the proposed command, prompts on /dev/tty
# (or auto-accepts when assume_yes=1), then runs the command inside <dest>.
# Caller is responsible for the non-tty / --no-deps gating.
prompt_install() {
  local dest="$1" assume_yes="$2"
  local toolchains
  toolchains=$(detect_toolchains "$dest")
  [ -z "$toolchains" ] && return 0

  info "detected toolchain(s) in new worktree:"
  local name cmd
  while IFS='|' read -r name cmd; do
    [ -z "$name" ] && continue
    printf '%b\n' "  ${C_DIM}-${C_RESET} ${C_CYAN}${name}${C_RESET}: ${C_DIM}\$${C_RESET} ${cmd}" >&2
  done <<< "$toolchains"

  local ans cmd_bin
  while IFS='|' read -r name cmd; do
    [ -z "$name" ] && continue
    if [ "$assume_yes" = "1" ]; then
      ans="y"
      info "auto-running ${C_CYAN}${name}${C_RESET} install (--yes)"
    else
      printf '%b' "run ${C_CYAN}${name}${C_RESET} install (${cmd})? ${C_DIM}[y/N]${C_RESET} " >&2
      if ! read -r ans </dev/tty 2>/dev/null; then
        info "no tty for prompt, skipping ${C_CYAN}${name}${C_RESET}"
        continue
      fi
    fi
    case "$ans" in
      y|Y|yes|YES)
        cmd_bin="${cmd%% *}"
        if ! command -v "$cmd_bin" >/dev/null 2>&1; then
          warn "${C_CYAN}${cmd_bin}${C_RESET} not found in PATH, skipping ${C_CYAN}${name}${C_RESET}"
          continue
        fi
        info "running ${C_DIM}\$${C_RESET} ${cmd} ${C_DIM}(in ${dest})${C_RESET}"
        # shellcheck disable=SC2086 -- intentional word-splitting on cmd
        (cd "$dest" && $cmd) >&2 || warn "${C_CYAN}${name}${C_RESET} install failed (continuing)"
        ;;
      *)
        info "skipping ${C_CYAN}${name}${C_RESET}"
        ;;
    esac
  done <<< "$toolchains"
}

cmd_switch() {
  require_git_repo
  local branch="" base="" no_deps=0 no_env=0 assume_yes=0
  case "${GWT_NO_DEPS:-}"    in ''|0) ;; *) no_deps=1 ;;    esac
  case "${GWT_NO_ENV:-}"     in ''|0) ;; *) no_env=1 ;;     esac
  case "${GWT_ASSUME_YES:-}" in ''|0) ;; *) assume_yes=1 ;; esac
  while [ $# -gt 0 ]; do
    case "$1" in
      --from)
        [ $# -ge 2 ] || die "--from requires a value"
        base="$2"; shift 2 ;;
      --from=*)
        base="${1#--from=}"
        [ -n "$base" ] || die "--from requires a value"
        shift ;;
      --no-deps)
        no_deps=1; shift ;;
      --no-env)
        no_env=1; shift ;;
      --yes|-y)
        assume_yes=1; shift ;;
      --)
        shift
        if [ $# -gt 0 ]; then
          [ -z "$branch" ] || die "unexpected argument: $1"
          branch="$1"; shift
        fi ;;
      -*)
        die "unknown flag: $1" ;;
      *)
        [ -z "$branch" ] || die "unexpected argument: $1"
        branch="$1"; shift ;;
    esac
  done

  if [ -z "$branch" ]; then
    [ -z "$base" ] || die "--from requires a branch name"
    if ! command -v fzf >/dev/null 2>&1; then
      err "fzf is required for the interactive picker"
      msg ""
      msg "  ${C_BOLD}install fzf:${C_RESET}"
      msg ""
      if command -v brew >/dev/null 2>&1; then
        msg "     ${C_CYAN}brew install fzf${C_RESET}"
      elif command -v apt-get >/dev/null 2>&1; then
        msg "     ${C_CYAN}sudo apt install fzf${C_RESET}"
      elif command -v pacman >/dev/null 2>&1; then
        msg "     ${C_CYAN}sudo pacman -S fzf${C_RESET}"
      elif command -v dnf >/dev/null 2>&1; then
        msg "     ${C_CYAN}sudo dnf install fzf${C_RESET}"
      fi
      msg ""
      msg "  ${C_DIM}or pass a branch name directly: git wt switch <branch>${C_RESET}"
      msg ""
      exit 2
    fi
    branch=$(git worktree list --porcelain \
      | awk '/^branch /{sub("refs/heads/","",$2); print $2}' \
      | fzf --height=40% --reverse --prompt='worktree> ') || exit 0
    [ -z "$branch" ] && exit 0
  fi

  local existing=""
  if [ -n "$base" ]; then
    git rev-parse --verify --quiet "$base^{commit}" >/dev/null 2>&1 \
      || die "base '$base' does not resolve to a commit"
    existing=$(worktree_path_for_branch "$branch")
    if [ -n "$existing" ]; then
      die "branch '$branch' is already checked out at ${C_MAGENTA}${existing}${C_RESET}; --from only applies to new branches"
    fi
    if local_branch_exists "$branch"; then
      die "local branch '$branch' already exists; --from only applies to new branches"
    fi
    if remote_branch_exists "$branch"; then
      die "remote branch 'origin/$branch' already exists; --from only applies to new branches"
    fi
  else
    existing=$(worktree_path_for_branch "$branch")
    if [ -n "$existing" ]; then
      report "switched to" "$branch" "$existing" \
        "git wt list" \
        "git wt rm $branch"
      printf '%s\n' "$existing"
      return 0
    fi
  fi

  local root dest origin
  root=$(worktrees_root)
  dest="$root/$(sanitize_branch "$branch")"
  mkdir -p "$root"

  if [ -n "$base" ]; then
    info "creating new branch ${C_CYAN}${branch}${C_RESET} from ${C_CYAN}${base}${C_RESET}"
    git worktree add --no-track -b "$branch" "$dest" "$base" >&2
    origin="new branch from $base"
  elif local_branch_exists "$branch"; then
    info "creating worktree for existing local branch ${C_CYAN}${branch}${C_RESET}"
    git worktree add "$dest" "$branch" >&2
    origin="local branch"
  elif remote_branch_exists "$branch"; then
    info "creating worktree tracking ${C_CYAN}origin/${branch}${C_RESET}"
    git worktree add --track -b "$branch" "$dest" "origin/$branch" >&2
    origin="tracking origin/$branch"
  else
    info "creating new branch ${C_CYAN}${branch}${C_RESET} from current HEAD"
    git worktree add -b "$branch" "$dest" >&2
    origin="new branch from HEAD"
  fi

  if [ "$no_env" != "1" ]; then
    bootstrap_env_files "$(main_worktree_path)" "$dest"
  fi
  if [ "$no_deps" != "1" ] && { [ -t 0 ] || [ "$assume_yes" = "1" ]; }; then
    prompt_install "$dest" "$assume_yes"
  fi

  report "created" "$branch ${C_DIM}(${origin})${C_RESET}" "$dest" \
    "git wt list" \
    "git push -u origin $branch" \
    "git wt rm $branch"
  printf '%s\n' "$dest"
}

cmd_list() {
  require_git_repo
  local current
  current=$(git rev-parse --show-toplevel)
  printf '\n%b\n\n' "${C_BOLD}worktrees${C_RESET}" >&2
  git worktree list --porcelain | awk \
    -v cur="$current" \
    -v cr="$C_RESET" -v cdim="$C_DIM" -v cb="$C_BOLD" \
    -v cgn="$C_GREEN" -v ccy="$C_CYAN" -v cmg="$C_MAGENTA" -v cyl="$C_YELLOW" '
    function emit() {
      if (path != "") {
        if (path == cur) {
          printf "  %s*%s %s%-40s%s %s%s%s\n", cgn, cr, cb ccy, branch, cr, cmg, path, cr
        } else {
          printf "    %s%-40s%s %s%s%s\n", ccy, branch, cr, cdim, path, cr
        }
      }
      path=""; branch=""
    }
    /^worktree / { emit(); path=$2 }
    /^branch /   { sub("refs/heads/","",$2); branch=$2 }
    /^detached/  { branch="(detached)" }
    END { emit() }
  ' >&2
  printf '\n%b\n' "  ${C_DIM}* = current${C_RESET}" >&2
  printf '\n' >&2
}

cmd_rm() {
  require_git_repo
  local branch="${1:-}"
  [ -z "$branch" ] && die "usage: git wt rm <branch>"

  local path main_path
  path=$(worktree_path_for_branch "$branch")
  [ -z "$path" ] && die "no worktree found for branch '$branch'"
  main_path=$(main_worktree_path)

  if [ "$path" = "$main_path" ]; then
    die "refusing to remove the main worktree at ${C_MAGENTA}${path}${C_RESET}"
  fi

  if [ -n "$(git -C "$path" status --porcelain 2>/dev/null)" ]; then
    warn "worktree at ${C_MAGENTA}${path}${C_RESET} has uncommitted changes"
    printf '%b' "remove anyway? ${C_DIM}[y/N]${C_RESET} " >&2
    read -r ans
    case "$ans" in y|Y|yes|YES) ;; *) info "aborted"; exit 1;; esac
    git worktree remove --force "$path" >&2
  else
    git worktree remove "$path" >&2
  fi

  local main_branch
  main_branch=$(git -C "$main_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
  report "removed" "$branch" "$path" \
    "git branch -d $branch  ${C_DIM}# if you also want to delete the branch${C_RESET}" \
    "git pull --ff-only  ${C_DIM}# sync the main worktree with origin${C_RESET}" \
    "git wt list"
  info "returning to main worktree ${C_CYAN}${main_branch}${C_RESET} at ${C_MAGENTA}${main_path}${C_RESET}"
  printf '%s\n' "$main_path"
}

case "${1:-help}" in
  switch)            shift; cmd_switch "$@" ;;
  list|ls)           shift || true; cmd_list ;;
  rm|remove)         shift; cmd_rm "$@" ;;
  help|-h|--help)    usage ;;
  version|--version) echo "$VERSION" ;;
  *) usage; exit 1 ;;
esac
